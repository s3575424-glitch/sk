```html
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>College Login</title>
    <style>
        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family: Arial, sans-serif;
        }

        body{
            height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            background:#f4f6f9;
        }

        .login-container{
            width:350px;
            background:#fff;
            padding:30px;
            border-radius:12px;
            box-shadow:0 4px 15px rgba(0,0,0,0.1);
            text-align:center;
        }

        .logo{
            width:100px;
            height:100px;
            object-fit:contain;
            margin-bottom:15px;
        }

        h2{
            margin-bottom:20px;
            color:#333;
        }

        .input-group{
            margin-bottom:15px;
        }

        input{
            width:100%;
            padding:12px;
            border:1px solid #ccc;
            border-radius:6px;
            font-size:16px;
        }

        button{
            width:100%;
            padding:12px;
            border:none;
            background:#0066cc;
            color:white;
            font-size:16px;
            border-radius:6px;
            cursor:pointer;
        }

        button:hover{
            background:#0052a3;
        }
    </style>
</head>
<body>

<div class="login-container">

    <!-- Replace with your actual college logo -->
    <img src="college-logo.png" alt="College Logo" class="logo">

    <h2>College Login</h2>

    <form>
        <div class="input-group">
            <input type="text" placeholder="Username" required>
        </div>

        <div class="input-group">
            <input type="password" placeholder="Password" required>
        </div>

        <button type="submit">Login</button>
    </form>

</div>

</body>
</html>
